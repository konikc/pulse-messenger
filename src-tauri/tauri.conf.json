{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Pulse",
  "version": "0.1.0",
  "identifier": "app.pulse.messenger",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:3000",
    "frontendDist": "../public"
  },
  "app": {
    "windows": [
      {
        "title": "Pulse",
        "url": "https://pulse-messenger.vercel.app",
        "width": 1180,
        "height": 780,
        "minWidth": 820,
        "minHeight": 620,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": ["icons/128x128.png", "icons/icon.png", "icons/icon.ico"],
    "publisher": "Pulse Messenger",
    "shortDescription": "Мягкий и быстрый мессенджер Pulse",
    "longDescription": "Pulse — современный мессенджер с чатами, реакциями, файлами и аудио- и видеозвонками.",
    "category": "SocialNetworking",
    "homepage": "https://github.com/konikc/pulse-messenger",
    "copyright": "Copyright © 2026 Pulse Messenger"
  }
}
