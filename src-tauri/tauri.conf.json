{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Pulse",
  "version": "0.1.0",
  "identifier": "app.pulse.messenger",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:3000",
    "frontendDist": "../public"
  },
  "app": {
    "windows": [
      {
        "title": "Pulse",
        "url": "https://pulse-messenger-chi.vercel.app",
        "width": 1180,
        "height": 780,
        "minWidth": 820,
        "minHeight": 620,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["msi", "nsis"],
    "shortDescription": "Мягкий и быстрый мессенджер Pulse",
    "category": "SocialNetworking"
  }
}
